# ============================================================
#  mall-app-web 商城 H5 前端 — 默认环境变量
#
#  【环境变量优先级】
#  Vite 的环境变量加载顺序：
#  1. .env                — 所有环境通用（本文件）
#  2. .env.development    — 开发环境专用（npm run dev）
#  3. .env.production     — 生产环境专用（npm run build）
#
#  同名变量后加载的会覆盖先加载的。
# ============================================================

# 应用标题
VITE_APP_TITLE=Mall商城

# API 基础地址（默认值，会被 .env.development 或 .env.production 覆盖）
# 本地开发时直连 mall-portal 的 8085 端口（不经过 Gateway）
VITE_API_BASE_URL=http://localhost:8085

# 调试模式开关
VITE_APP_DEBUG=false

# 支付宝支付开关（H5 端功能）
VITE_USE_ALIPAY=false
